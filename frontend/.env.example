# ClaimGuard frontend environment
# By default the app calls the backend through the Vite dev proxy (/api → :8000),
# so these are only needed to point at a different backend.

# REST base URL (default: /api/v1 via dev proxy)
# VITE_API_BASE_URL=http://localhost:8000/api/v1

# WebSocket URL (default: same-origin /api/v1/ws via dev proxy)
# VITE_WS_URL=ws://localhost:8000/api/v1/ws

# Where the dev server proxies /api to (default: http://localhost:8000)
# VITE_PROXY_TARGET=http://localhost:8000
