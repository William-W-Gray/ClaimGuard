# ─── ClaimGuard 360° Backend — Environment (12-factor) ─────────────────────────
# Copy to `.env` and adjust. Never commit real secrets.

# App
APP_NAME="ClaimGuard 360°"
ENVIRONMENT=development          # development | staging | production
DEBUG=true
API_V1_PREFIX=/api/v1
LOG_LEVEL=INFO
LOG_JSON=false                   # true => JSON logs (prod)

# Server
HOST=0.0.0.0
PORT=8000

# Security  (generate with: openssl rand -hex 32)
JWT_SECRET_KEY=change-me-dev-secret-do-not-use-in-prod
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS (comma-separated origins; * allowed only in dev)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Rate limiting
RATE_LIMIT_PER_MINUTE=120

# Database (async driver)
DATABASE_URL=postgresql+asyncpg://claimguard:claimguard@localhost:5432/claimguard
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_ECHO=false

# Redis
REDIS_URL=redis://localhost:6379/0

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Demo / seed
DEMO_MODE=true
SEED_ON_STARTUP=false

# First admin user (created by seed)
FIRST_ADMIN_EMAIL=admin@claimguard.co.zw
FIRST_ADMIN_PASSWORD=ChangeMe!2026
