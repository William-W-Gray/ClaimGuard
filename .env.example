# ClaimGuard — root environment for docker compose. Copy to `.env`.

# ── Database ─────────────────────────────────────────────────────────────────
# Managed Postgres (Neon / RDS / Cloud SQL). Use the DIRECT (non-pooled) endpoint
# and the asyncpg driver + ssl=require. Example (Neon):
#   DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@ep-xxxx.REGION.aws.neon.tech/DBNAME?ssl=require
DATABASE_URL=

# Leave DATABASE_URL blank to fall back to a local Postgres container instead —
# start it with the `local-db` profile:
#   docker compose --profile local-db up --build

# ── Security ─────────────────────────────────────────────────────────────────
# openssl rand -hex 32
JWT_SECRET_KEY=change-me-compose-secret-not-for-real-prod
